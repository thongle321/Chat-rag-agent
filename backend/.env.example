ENVIRONMENT=development

# AI Provider: "ollama" or "openai"
AI_PROVIDER=ollama

# OpenAI (if using openai provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Ollama (if using ollama provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings (local, no API key needed)
EMBEDDING_MODEL=jinaai/jina-embeddings-v5-text-nano

# Storage
UPLOAD_DIR=data/uploads
VECTOR_STORE_DIR=.chromadb

# Production (Railway) — set these env vars in the Railway dashboard:
#   ENVIRONMENT=production
#   ALLOWED_CORS_ORIGINS=https://your-app.vercel.app
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-your-real-key-here
# For production, also switch the AI_PROVIDER above from "ollama" to "openai".
